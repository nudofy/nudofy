{
  "expo": {
    "name": "Nudofy",
    "slug": "nudofy",
    "version": "1.1.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#E73121"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nudofy.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Necesitamos acceso a tu galería para subir el logo del proveedor."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E73121"
      },
      "package": "com.nudofy.app",
      "splash": {
        "image": "./assets/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#E73121"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-document-picker",
      [
        "expo-build-properties",
        {
          "android": {
            "targetSdkVersion": 35,
            "compileSdkVersion": 35,
            "useLegacyPackaging": false
          }
        }
      ]
    ],
    "scheme": "nudofy",
    "extra": {
      "eas": {
        "projectId": "40847a34-c16b-4316-a2a2-a25eb2dcafef"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "nudofy"
  }
}
